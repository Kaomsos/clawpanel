# -----------------------------------------------------------------------------
# ClawPanel / OpenClaw / Hermes deployment environment example
# Copy to `.env` before running docker compose.
# -----------------------------------------------------------------------------

# Common
TZ=Asia/Shanghai

# Published ports on the host
CLAWPANEL_PORT=1420
OPENCLAW_GATEWAY_PORT=18789
HERMES_GATEWAY_PORT=8642

# Host data directories
OPENCLAW_DATA_DIR=./data/openclaw
HERMES_DATA_DIR=./data/hermes
HERMES_LOG_DIR=./data/hermes-logs
PANEL_DATA_DIR=./data/panel

# -----------------------------------------------------------------------------
# Fullstack single-container profile
# Used by: docker-compose.fullstack.yml
# -----------------------------------------------------------------------------
FULLSTACK_IMAGE_NAME=clawpanel-fullstack:local
FULLSTACK_CONTAINER_NAME=clawpanel-fullstack
AUTO_START_OPENCLAW_GATEWAY=1
AUTO_START_HERMES_GATEWAY=0

# -----------------------------------------------------------------------------
# Two-container profile
# Used by: docker-compose.two-containers.yml
# -----------------------------------------------------------------------------
TWO_CONTAINER_PANEL_IMAGE_NAME=clawpanel-openclaw:local
TWO_CONTAINER_PANEL_NAME=clawpanel-openclaw
TWO_CONTAINER_HERMES_IMAGE_NAME=hermes-agent:local
TWO_CONTAINER_HERMES_NAME=hermes-agent
HERMES_EXTERNAL_URL=http://hermes:8642

# -----------------------------------------------------------------------------
# Hermes runtime settings
# Required if Hermes gateway should really start.
# -----------------------------------------------------------------------------
HERMES_PROVIDER=openai
HERMES_MODEL=gpt-4o
HERMES_BASE_URL=
HERMES_API_KEY=

# Examples:
# HERMES_PROVIDER=openrouter
# HERMES_MODEL=anthropic/claude-sonnet-4
# HERMES_BASE_URL=https://openrouter.ai/api/v1
# HERMES_API_KEY=sk-...
